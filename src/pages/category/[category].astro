---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PostCard from '../../components/PostCard.astro';
import { categories, getPostsByCategory, getCategoryLabel } from '../../lib/mockData';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat },
    props: { category: cat },
  }));
}

interface Props {
  category: string;
}

const { category } = Astro.props;
const categoryLabel = getCategoryLabel(category);
const filteredPosts = getPostsByCategory(category).sort(
  (a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);

const categoryFilters = [
  { label: '全て', href: '/posts/', key: 'all' },
  ...categories.map((cat) => ({
    label: getCategoryLabel(cat).replace('年度のお知らせ', ''),
    href: `/category/${cat}/`,
    key: cat,
  })),
];
---

<BaseLayout title={categoryLabel}>
  <Breadcrumb items={[
    { label: '経営者の気づきとまなび', href: '/posts/' },
    { label: categoryLabel },
  ]} />

  <section class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-2xl md:text-3xl font-bold mb-8">{categoryLabel}</h1>

    <div class="flex flex-wrap gap-2 mb-8">
      {categoryFilters.map((filter) => (
        <a
          href={filter.href}
          class:list={[
            'px-4 py-2 rounded text-sm font-medium transition-colors',
            filter.key === category
              ? 'bg-primary text-white'
              : 'bg-bg-gray text-text-light hover:bg-primary-light hover:text-primary',
          ]}
        >
          {filter.label}
        </a>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {filteredPosts.map((post) => (
        <PostCard
          title={post.title}
          slug={post.slug}
          category={post.category}
          publishedAt={post.publishedAt}
          excerpt={post.excerpt}
        />
      ))}
    </div>

    <div class="mt-8 text-center text-sm text-text-light">
      全 {filteredPosts.length} 件
    </div>
  </section>
</BaseLayout>
