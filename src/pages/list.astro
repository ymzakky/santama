---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import MemberTable from '../components/MemberTable.astro';
import { members } from '../lib/mockData';
---

<BaseLayout title="会員企業一覧">
  <Breadcrumb items={[{ label: '会員企業一覧' }]} />

  <section class="py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-4">
      <h1 class="mb-6 text-3xl font-bold text-primary-dark md:text-4xl">会員企業一覧</h1>
      <p class="mb-10 text-lg leading-relaxed text-text-light">
        東京中小企業家同友会 三多摩支部に所属する会員企業をご紹介します。多摩地域を中心に、さまざまな業種の中小企業が活動しています。
      </p>

      <MemberTable members={members} />

      <p class="mt-8 text-sm text-text-light">※ 掲載情報は2025年4月現在のものです</p>
    </div>
  </section>
</BaseLayout>
