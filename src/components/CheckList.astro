---
interface Props {
  items: string[];
  columns?: 1 | 2;
}
const { items, columns = 1 } = Astro.props;
---

<div class:list={['grid gap-3', columns === 2 ? 'grid-cols-1 md:grid-cols-2' : 'grid-cols-1']}>
  {items.map(item => (
    <div class="flex items-center gap-2 text-text-light text-sm">
      <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      {item}
    </div>
  ))}
</div>
