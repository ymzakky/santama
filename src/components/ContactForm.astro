---
---

<form id="contact-form" class="max-w-2xl mx-auto space-y-6">
  <!-- Interest checkboxes -->
  <fieldset>
    <legend class="block text-sm font-bold text-text mb-3">
      ご興味のある項目<span class="text-red-500 ml-1">*</span>
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="interest" value="例会のお試し参加" class="w-4 h-4 text-primary rounded" />
        例会のお試し参加
      </label>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="interest" value="入会について" class="w-4 h-4 text-primary rounded" />
        入会について
      </label>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="interest" value="経営指針セミナー" class="w-4 h-4 text-primary rounded" />
        経営指針セミナー
      </label>
      <label class="flex items-center gap-2 text-sm">
        <input type="checkbox" name="interest" value="その他のお問い合わせ" class="w-4 h-4 text-primary rounded" />
        その他のお問い合わせ
      </label>
    </div>
  </fieldset>

  <!-- Name -->
  <div>
    <label for="name" class="block text-sm font-bold text-text mb-1">
      お名前<span class="text-red-500 ml-1">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-2 border border-border rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="例：山田 太郎"
    />
  </div>

  <!-- Company -->
  <div>
    <label for="company" class="block text-sm font-bold text-text mb-1">
      会社名
    </label>
    <input
      type="text"
      id="company"
      name="company"
      class="w-full px-4 py-2 border border-border rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="例：株式会社○○"
    />
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="block text-sm font-bold text-text mb-1">
      メールアドレス<span class="text-red-500 ml-1">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-2 border border-border rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="例：info@example.com"
    />
  </div>

  <!-- Phone -->
  <div>
    <label for="phone" class="block text-sm font-bold text-text mb-1">
      電話番号
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      class="w-full px-4 py-2 border border-border rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
      placeholder="例：042-000-0000"
    />
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-bold text-text mb-1">
      お問い合わせ内容
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      class="w-full px-4 py-2 border border-border rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-y"
      placeholder="お問い合わせ内容をご記入ください"
    ></textarea>
  </div>

  <!-- Submit -->
  <div class="text-center">
    <button
      type="button"
      id="confirm-btn"
      class="px-8 py-3 bg-primary text-white font-bold rounded hover:bg-primary-dark transition-colors"
    >
      確認画面へ
    </button>
  </div>
</form>

<!-- Confirm modal -->
<div id="confirm-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-lg max-w-lg w-full max-h-[80vh] overflow-y-auto p-8">
    <h3 class="text-lg font-bold mb-6 text-center">入力内容の確認</h3>
    <div id="confirm-content" class="space-y-4 mb-6"></div>
    <div class="flex gap-4 justify-center">
      <button id="back-btn" class="px-6 py-2 border border-border rounded hover:bg-bg-gray transition-colors">
        戻る
      </button>
      <button id="submit-btn" class="px-6 py-2 bg-primary text-white font-bold rounded hover:bg-primary-dark transition-colors">
        送信する
      </button>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const confirmBtn = document.getElementById('confirm-btn');
  const modal = document.getElementById('confirm-modal');
  const confirmContent = document.getElementById('confirm-content');
  const backBtn = document.getElementById('back-btn');
  const submitBtn = document.getElementById('submit-btn');

  confirmBtn?.addEventListener('click', () => {
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const data = new FormData(form);
    const interests = data.getAll('interest').join(', ');
    const items = [
      { label: 'ご興味のある項目', value: interests },
      { label: 'お名前', value: data.get('name') as string },
      { label: '会社名', value: data.get('company') as string },
      { label: 'メールアドレス', value: data.get('email') as string },
      { label: '電話番号', value: data.get('phone') as string },
      { label: 'お問い合わせ内容', value: data.get('message') as string },
    ];
    if (confirmContent) {
      confirmContent.innerHTML = items
        .filter(i => i.value)
        .map(i => `<div class="border-b border-border pb-3"><p class="text-xs text-text-light mb-1">${i.label}</p><p class="text-sm">${i.value}</p></div>`)
        .join('');
    }
    modal?.classList.remove('hidden');
  });

  backBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
  });

  submitBtn?.addEventListener('click', () => {
    window.location.href = '/contact/complete/';
  });
</script>
