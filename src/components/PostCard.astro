---
interface Props {
  title: string;
  slug: string;
  category: string;
  publishedAt: string;
  excerpt: string;
}
const { title, slug, category, publishedAt, excerpt } = Astro.props;
import { categoryLabels } from '../lib/mockData';
---

<article class="bg-white rounded-lg shadow-sm border border-border overflow-hidden hover:shadow-md transition-shadow">
  <div class="aspect-video bg-bg-gray flex items-center justify-center">
    <svg class="w-16 h-16 text-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
  </div>
  <div class="p-5">
    <div class="flex items-center gap-3 mb-2">
      <time class="text-xs text-text-light">{publishedAt}</time>
      <span class="text-xs bg-primary-light text-primary px-2 py-0.5 rounded font-medium">
        {categoryLabels[category] || category}
      </span>
    </div>
    <h3 class="font-bold text-text mb-2 line-clamp-2">
      <a href={`/${category}/${slug}/`} class="hover:text-primary transition-colors">
        {title}
      </a>
    </h3>
    <p class="text-sm text-text-light line-clamp-3">{excerpt}</p>
  </div>
</article>
